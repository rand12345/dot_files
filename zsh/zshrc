# Dotfiles - Main ZSH Configuration
# Works on macOS and Linux (Kali)

# Detect OS
if [[ "$OSTYPE" == "darwin"* ]]; then
    export DOTFILES_OS="macos"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    export DOTFILES_OS="linux"
fi

# Path to Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme configuration
# Customize per machine if needed, default to robbyrussell
ZSH_THEME="robbyrussell"

# Oh My Zsh settings
ENABLE_CORRECTION="true"
HIST_STAMPS="yyyy-mm-dd"
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Core plugins (work on all platforms)
plugins=(
    git
    sudo
    tmux
    vim-interaction
    fzf
)

# Load Oh My Zsh
source $ZSH/oh-my-zsh.sh

# ============================================================================
# Custom Prompt with Hostname
# ============================================================================

# Enable parameter expansion, command substitution and arithmetic expansion in prompts
setopt PROMPT_SUBST

# Custom prompt that includes hostname
# Format: [user@hostname] directory (git_branch)
# Colors: cyan for user@host, blue for directory, yellow for git
PROMPT='%{$fg[cyan]%}[%n@%m]%{$reset_color%} %{$fg[blue]%}%~%{$reset_color%} $(git_prompt_info)
%{$fg[green]%}➜%{$reset_color%} '

# Right prompt with time (optional - comment out if not wanted)
# RPROMPT='%{$fg[yellow]%}%T%{$reset_color%}'

# Git prompt info (customize these if you want different git prompt styling)
ZSH_THEME_GIT_PROMPT_PREFIX="%{$fg[yellow]%}("
ZSH_THEME_GIT_PROMPT_SUFFIX=")%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_DIRTY=" %{$fg[red]%}✗%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_CLEAN=" %{$fg[green]%}✓%{$reset_color%}"

# ============================================================================
# User Configuration
# ============================================================================

# Preferred editor
if command -v nvim &> /dev/null; then
    export EDITOR='nvim'
    export VISUAL='nvim'
elif command -v vim &> /dev/null; then
    export EDITOR='vim'
    export VISUAL='vim'
else
    export EDITOR='nano'
    export VISUAL='nano'
fi

# Language environment
export LANG=en_US.UTF-8

# ============================================================================
# Common Aliases
# ============================================================================

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# List files
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'

# Git shortcuts
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# ============================================================================
# Network Information Display
# ============================================================================

# Display hostname
hostname

# Display WAN IP (with timeout to avoid hanging)
if command -v curl &> /dev/null; then
    WANIP=$(timeout 2 curl -s ifconfig.me 2>/dev/null || echo "N/A")
    echo "WAN IP: $WANIP"
fi

# Display LAN IP
if command -v ifconfig &> /dev/null; then
    LANIP=$(ifconfig | grep 'inet ' | grep -v '127.0.0.1' | cut -f2 -d ' ' | tr '\n' ' ')
    echo "LAN IP: $LANIP"
elif command -v ip &> /dev/null; then
    # Linux alternative
    LANIP=$(ip -4 addr | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v '127.0.0.1' | tr '\n' ' ')
    echo "LAN IP: $LANIP"
fi

# ============================================================================
# Terminal & Claude Code
# ============================================================================

# 24-bit colour support (required for Claude Code TUI and modern terminal apps)
export COLORTERM=truecolor

# ============================================================================
# SSH — use a generic TERM so remote hosts don't need ghostty terminfo
# ============================================================================

function ssh() {
    TERM=xterm-256color command ssh "$@"
}

# ============================================================================
# Tmux session manager (iTerm2-style window arranger replacement)
# Usage: `tm` to fuzzy-pick or create a tmux session
# ============================================================================

function tm() {
    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null)

    if ! command -v fzf &>/dev/null; then
        echo "fzf not found; run: brew install fzf"
        return 1
    fi

    local selected
    selected=$(
        {
            echo "$sessions"
            echo "[new session]"
        } | fzf --prompt="tmux> " --height=40% --reverse --border \
              --preview 'tmux list-windows -t {} 2>/dev/null || echo "(new)"' \
              --preview-window=right:50%
    )

    [[ -z "$selected" ]] && return 0

    if [[ "$selected" == "[new session]" ]]; then
        local name
        read "name?Session name: "
        [[ -z "$name" ]] && name="main"
        tmux new-session -s "$name"
    elif [[ -n "$TMUX" ]]; then
        tmux switch-client -t "$selected"
    else
        tmux attach-session -t "$selected"
    fi
}

# History — larger size and deduplication improve Claude's shell-history context
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY        # sync history across all open sessions
setopt HIST_IGNORE_DUPS     # skip consecutive duplicates
setopt HIST_IGNORE_ALL_DUPS # remove older duplicate when a new one is added
setopt HIST_IGNORE_SPACE    # space-prefixed commands are not saved (privacy)
setopt HIST_REDUCE_BLANKS   # strip extra whitespace before saving

# Claude Code shorthand
if command -v claude &> /dev/null; then
    alias cc='claude'
fi

# ============================================================================
# Rust/Cargo Environment
# ============================================================================

if [ -f "$HOME/.cargo/env" ]; then
    . "$HOME/.cargo/env"
fi

# ============================================================================
# Platform-Specific Configurations
# ============================================================================

# Load macOS-specific config
if [[ "$DOTFILES_OS" == "macos" ]] && [[ -f "$HOME/dotfiles/zsh/zshrc.macos" ]]; then
    source "$HOME/dotfiles/zsh/zshrc.macos"
fi

# Load Linux-specific config
if [[ "$DOTFILES_OS" == "linux" ]] && [[ -f "$HOME/dotfiles/zsh/zshrc.linux" ]]; then
    source "$HOME/dotfiles/zsh/zshrc.linux"
fi

# ============================================================================
# Local Machine-Specific Configuration (not in git)
# ============================================================================

# Source local config if it exists (for machine-specific customizations)
if [[ -f "$HOME/.zshrc.local" ]]; then
    source "$HOME/.zshrc.local"
fi
